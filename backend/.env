# Provider Config
MODEL_PROVIDER=groq
MODEL_NAME=llama-3.3-70b-versatile
GROQ_API_KEY=
OPENROUTER_API_KEY=

# SQL Server - Inventory
# Update with your actual server instance
HR_DB_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=InventoryDB;Trusted_Connection=yes;
SALES_DB_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=InventoryDB;Trusted_Connection=yes;

# PostgreSQL - Sales
PG_DB_CONN=dbname=SalesDB user=postgres password=postgres host=localhost port=5432

# MongoDB - Customers
MONGO_URI=mongodb://localhost:27017/
CUSTOMER_DB=CustomerDB
