# OpenRouter API Configuration
OPENROUTER_API_KEY=
GROQ_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_PROVIDER=groq
MODEL_NAME=openai/gpt-oss-120b

# Database Connection Settings (SQLAlchemy Format)
# For SQLite: sqlite:///hr.db
# For Postgres: postgresql://user:pass@localhost:5432/hr_db
# For MySQL: mysql+pymysql://user:pass@localhost:3306/hr_db
HR_DB_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=HospitalDB;Trusted_Connection=yes;
SALES_DB_CONN=DRIVER={ODBC Driver 17 for SQL Server};SERVER=(localdb)\MSSQLLocalDB;DATABASE=FacilityDB;Trusted_Connection=yes;
PG_DB_CONN=dbname=pharmacy_db user=postgres password=postgres host=localhost port=5432
MONGO_URI=mongodb://localhost:27017/

